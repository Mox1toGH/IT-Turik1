DJANGO_SECRET_KEY=replace-me
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:5173

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
NOTIFICATIONS_ASYNC=True

GOOGLE_OAUTH_CLIENT_ID=your-google-web-client-id.apps.googleusercontent.com

GOOGLE_SHEETS_SERVICE_ACCOUNT_INFO='{JSON_CONTENT_OF_YOUR_SERVICE_ACCOUNT_KEY_FILE}'
GOOGLE_SHEETS_DEFAULT_SHARE_WITH=your-email@gmail.com
